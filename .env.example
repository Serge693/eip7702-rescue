# ── Required ──────────────────────────────────────────────────────────────────
SOURCE_PRIVATE_KEY=0x...        # Compromised wallet private key
SPONSOR_PRIVATE_KEY=0x...       # Wallet that pays gas (keep funded)
DESTINATION_ADDRESS=0x...       # Where rescued funds go

# ── Pre-deployed Rescuer contracts (optional but recommended) ─────────────────
# Deploy once with: npx tsx src/index.ts deploy <network>
# Then paste the address here — saves gas on every rescue.
RESCUER_BASE=
RESCUER_ETHEREUM=
RESCUER_INK=
RESCUER_ARBITRUM=
RESCUER_OPTIMISM=
RESCUER_POLYGON=

# ── Custom RPCs (optional) ────────────────────────────────────────────────────
# Default public RPCs are used if not set.
# For guard mode, a paid RPC with WebSocket is strongly recommended.
RPC_URL_BASE=
RPC_URL_ETHEREUM=
RPC_URL_INK=
RPC_URL_ARBITRUM=
RPC_URL_OPTIMISM=
RPC_URL_POLYGON=

# ── Guard tuning (optional) ───────────────────────────────────────────────────
SPONSOR_MIN_BALANCE=0.005       # Warn if sponsor drops below this (ETH)
DRY_RUN=false                   # Set true to simulate without sending tx
