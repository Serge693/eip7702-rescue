# ── Required ──────────────────────────────────────────────────────────────────
SOURCE_PRIVATE_KEY=0x...        # Compromised wallet private key
SPONSOR_PRIVATE_KEY=0x...       # Wallet that pays gas (keep funded!)
DESTINATION_ADDRESS=0x...       # Safe destination (public address only!)

# ── Pre-deployed Rescuer contracts ────────────────────────────────────────────
# Already deployed — copy these as-is, no need to redeploy
RESCUER_BASE=0x6dd487e62ac3a1e0adf1a4a92a3e135aee6f5d70
RESCUER_ETHEREUM=0xf55b2fc1c86dcd1c9f566d8fa6c71b8b800024a0
RESCUER_INK=0x1f759dfedbc5f423bf7e091bfcc04f7058c8d7d1
RESCUER_ARBITRUM=0x325ae83fb09c4c704b7cd92061deba19a665e676
RESCUER_OPTIMISM=0xa7e9ad4ece09b7e3350261349ceda92c1f5dbc45
RESCUER_POLYGON=0xfbcde80008f8a0b1b5093cd5e7476974d4230a57

# ── Custom RPCs (optional but recommended for guard mode) ─────────────────────
# Default public RPCs are used if not set.
# For guard mode, a paid RPC with WebSocket support is strongly recommended.
RPC_URL_BASE=
RPC_URL_ETHEREUM=
RPC_URL_INK=
RPC_URL_ARBITRUM=
RPC_URL_OPTIMISM=
RPC_URL_POLYGON=

# ── Guard tuning (optional) ───────────────────────────────────────────────────
SPONSOR_MIN_BALANCE=0.005       # Warn if sponsor drops below this (ETH)
DRY_RUN=false                   # Set true to simulate without sending tx
